    },
    {
      "type": "rectangle",
      "id": "leg_b",
      "x": 555,
      "y": 826,
      "width": 440,
      "height": 110,
      "strokeColor": "#a55b1c",
      "backgroundColor": "#f3973f",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
