    {
      "type": "text",
      "id": "leg_a_t",
      "x": 92,
      "y": 836,
      "width": 416,
      "height": 90,
      "text": "ZONE A - committed / permanent\nGit history, versioned -> audit-proof.\nspecs/, dpo/reports/, journal/sprint-*.md,\nSECURITY.md, branch protection\nDefensibility: STRONG",
      "originalText": "ZONE A - committed / permanent\nGit history, versioned -> audit-proof.\nspecs/, dpo/reports/, journal/sprint-*.md,\nSECURITY.md, branch protection\nDefensibility: STRONG",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "middle",
      "strokeColor": "#1d1d1b",
      "backgroundColor": "transparent",
