    {
      "type": "text",
      "id": "leg_c_t",
      "x": 1042,
      "y": 836,
      "width": 416,
      "height": 90,
      "text": "ZONE C - local / gitignored / ephemeral\nOnly on the operator machine, never in Git.\njournal/reports/local/, meta.json,\n*.sarif, *.junit.xml, coverage-final.json\nDefensibility: WEAK (no audit evidence)",
      "originalText": "ZONE C - local / gitignored / ephemeral\nOnly on the operator machine, never in Git.\njournal/reports/local/, meta.json,\n*.sarif, *.junit.xml, coverage-final.json\nDefensibility: WEAK (no audit evidence)",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "middle",
      "strokeColor": "#1d1d1b",
