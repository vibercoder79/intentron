    {
      "type": "text",
      "id": "footnote",
      "x": 80,
      "y": 952,
      "width": 1390,
      "height": 22,
      "text": "Rule of thumb: anything that must be audit-proof must live in zone A. Zone B is the 30-day window - download in time. Zone C proves nothing to a reviewer.",
      "originalText": "Rule of thumb: anything that must be audit-proof must live in zone A. Zone B is the 30-day window - download in time. Zone C proves nothing to a reviewer.",
