    },
    {
      "type": "text",
      "id": "leg_b_t",
      "x": 567,
      "y": 836,
      "width": 416,
      "height": 90,
      "text": "ZONE B - CI artifact / 30 days\nGitHub Actions run, via gh run download.\njournal/reports/ci/run-{id}/ (SARIF / JUnit /\ncoverage) - unrecoverable afterwards.\nDefensibility: MEDIUM (time-limited)",
      "originalText": "ZONE B - CI artifact / 30 days\nGitHub Actions run, via gh run download.\njournal/reports/ci/run-{id}/ (SARIF / JUnit /\ncoverage) - unrecoverable afterwards.\nDefensibility: MEDIUM (time-limited)",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "middle",
      "strokeColor": "#1d1d1b",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "angle": 0,
